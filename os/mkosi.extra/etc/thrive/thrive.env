# thriveOS appliance config — read by thrive.service / thrive-bootstrap.
# Override these to track a fork, a branch, or a different install location.
THRIVE_REPO=https://github.com/nerfarrow/thrive.git
THRIVE_BRANCH=main
THRIVE_DIR=/opt/thrive
# The platform shell within the repo — compose lives here and mounts ../modules.
# Defaults to $THRIVE_DIR/core. Keep in sync with thrive.service WorkingDirectory.
THRIVE_CORE=/opt/thrive/core
